# =============================================================
# PM Copilot — Variables de entorno
# Copia este fichero a .env y rellena los valores reales.
# NUNCA comitees el .env con credenciales reales.
# =============================================================

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_DB=pmcopilot
POSTGRES_USER=pmcopilot
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# URL para SQLAlchemy (construida desde las variables anteriores)
DATABASE_URL=postgresql+asyncpg://pmcopilot:changeme@localhost:5432/pmcopilot

# ─────────────────────────────────────────
# ChromaDB
# ─────────────────────────────────────────
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# ─────────────────────────────────────────
# pgAdmin (opcional — solo con: make tools-up)
# ─────────────────────────────────────────
PGADMIN_EMAIL=admin@pmcopilot.local
PGADMIN_PASSWORD=changeme

# ─────────────────────────────────────────
# LLM — Anthropic Claude
# Obtén tu API key en: https://console.anthropic.com
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────
# LLM — Groq (tier gratuito)
# Obtén tu API key en: https://console.groq.com
# ─────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ─────────────────────────────────────────
# LLM — Google Gemini (tier gratuito)
# Obtén tu API key en: https://aistudio.google.com
# ─────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ─────────────────────────────────────────
# LLM — Ollama (local)
# ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Modo de LLM: local | hybrid | cloud
LLM_MODE=local

# ─────────────────────────────────────────
# Confluence
# ─────────────────────────────────────────
CONFLUENCE_BASE_URL=https://<tu-instancia>.atlassian.net/wiki
CONFLUENCE_URL=https://<tu-instancia>.atlassian.net
CONFLUENCE_EMAIL=tu@email.com
CONFLUENCE_API_TOKEN=<token>
CONFLUENCE_SPACE_KEY=PBPMIA

# ─────────────────────────────────────────
# Jira
# ─────────────────────────────────────────
JIRA_URL=https://<tu-instancia>.atlassian.net
JIRA_EMAIL=tu@email.com
JIRA_API_TOKEN=<token>

# ─────────────────────────────────────────
# GitHub
# ─────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ─────────────────────────────────────────
# Aplicación
# ─────────────────────────────────────────
SECRET_KEY=cambia-esto-en-produccion
DEBUG=true
